# Copy this to .env and fill in your values
# Generate SECRET_KEY with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/plantit
DATABASE_URL_SYNC=postgresql://user:password@localhost:5432/plantit

# LLM provider: anthropic | openai
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=plantit-images
